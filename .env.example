# ══════════════════════════════════════════════════════════════════════════════
# StartupPilot AI — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys.
# At minimum, you need ONE LLM provider key (Groq is free).
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider API Keys (at least one required) ─────────────────────────────
# Get free Groq key: https://console.groq.com/keys
GROQ_API_KEY=

# Get OpenAI key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Get DeepSeek key: https://platform.deepseek.com/api-keys
DEEPSEEK_API_KEY=

# Get OpenRouter key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
APIFREELLM_API_KEY=

# Get Alibaba Cloud Model Studio (DashScope) key: https://modelstudio.console.alibabacloud.com
DASHSCOPE_API_KEY=

# ── LLM Defaults ──────────────────────────────────────────────────────────────
LLM_PROVIDER=apifreellm
DEFAULT_MODEL=apifreellm
FALLBACK_PROVIDER=openai
FALLBACK_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# ── RAG Settings ──────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5

# ── File Paths (defaults work for local dev) ──────────────────────────────────
UPLOAD_DIR=./data/uploads
REPORTS_DIR=./data/reports
CHROMA_PERSIST_DIR=./data/chroma
MEMORY_DIR=./data/memory

# ── Backend Settings ──────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=8501

# ── Failure Recovery ──────────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY_SECONDS=2.0
REQUEST_TIMEOUT_SECONDS=120

# ── AutoGen ───────────────────────────────────────────────────────────────────
AUTOGEN_MAX_ROUNDS=6

# ── LangSmith Tracing (optional) ─────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=startuppilot-ai
